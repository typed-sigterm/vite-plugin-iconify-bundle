{
  "name": "vite-plugin-iconify-bundle",
  "type": "module",
  "version": "1.0.0",
  "description": "On-demand bundle Iconify icons to the client.",
  "author": "Typed SIGTERM",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/typed-sigterm/vite-plugin-iconify-bundle.git"
  },
  "keywords": [
    "rolldown-plugin",
    "vite-plugin"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    },
    "./client": {
      "types": "./client.d.ts"
    },
    "./package.json": "./package.json"
  },
  "module": "src/index.ts",
  "files": [
    "LICENSE",
    "README.md",
    "client.d.ts",
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vite": "^7.0.0 || ^8.0.0"
  },
  "dependencies": {
    "tinyglobby": "0.2.16"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@iconify-json/lucide": "^1.2.109",
    "@iconify-json/simple-icons": "^1.2.84",
    "@iconify/types": "^2.0.0",
    "@iconify/vue": "^5.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@tsconfig/bun": "^1.0.10",
    "@typed-sigterm/eslint-config": "^1.7.1",
    "@types/bun": "1.3.14",
    "eslint": "^10.4.0",
    "rolldown": "^1.0.3",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
